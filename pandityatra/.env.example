# PanditYatra root environment example
# Copy this file to `.env` in the project root: pandityatra/.env
# Docker Compose and Django already read the root `.env` from here.
# Frontend Vite variables are included too for convenience.

# -----------------------------------------------------------------------------
# Core Django / Backend
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgres://pandit_admin:secure_password@db:5432/pandityatra_db
REDIS_URL=redis://redis:6379/0

# Security / CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8000
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------------
# Email (Gmail SMTP)
# -----------------------------------------------------------------------------
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Khalti
# -----------------------------------------------------------------------------
KHALTI_SECRET_KEY=
KHALTI_PUBLIC_KEY=
KHALTI_API_URL=https://khalti.com/api/v2

# -----------------------------------------------------------------------------
# eSewa
# -----------------------------------------------------------------------------
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_TEST_MODE=True
ESEWA_SANDBOX_API_URL=https://rc-epay.esewa.com.np
ESEWA_API_URL=https://epay.esewa.com.np

# -----------------------------------------------------------------------------
# Daily.co Video
# -----------------------------------------------------------------------------
DAILY_API_KEY=
DAILY_ENABLE_RECORDING=False

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Frontend (Vite)
# If you use a separate frontend .env file, copy these values there as well.
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
# JSON array. Example for TURN:
# VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]
VITE_GOOGLE_CLIENT_ID=
