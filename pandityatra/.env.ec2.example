# ==============================================================================
# PANDITYATRA BACKEND ENVIRONMENT VARIABLES (AWS EC2 PRODUCTION)
# ==============================================================================

# 1. Django Core Settings
DEBUG=False
SECRET_KEY=generate_a_secure_random_key_here
ALLOWED_HOSTS=your_ec2_ip,your_domain.com

# 2. Database (PostgreSQL inside Docker)
POSTGRES_DB=pandityatra_db
POSTGRES_USER=pandit_admin
POSTGRES_PASSWORD=use_a_strong_password_here

# 3. Frontend Integration (Vercel)
# Change these to your actual Vercel deployment URL
FRONTEND_URL=https://pandityatra.vercel.app
CORS_ALLOWED_ORIGINS=https://pandityatra.vercel.app
CSRF_TRUSTED_ORIGINS=https://pandityatra.vercel.app

# 4. Redis/Cache/Channels
REDIS_URL=redis://redis:6379/0

# 5. Media/Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 6. Email Settings
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# 7. OAuth (Google)
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

# 8. WebRTC (Coturn)
TURN_USERNAME=pandityatra
TURN_PASSWORD=choose_a_turn_password
TURN_REALM=your_domain.com
# Leave blank for auto-detect or set to your EC2 Public IP
TURN_EXTERNAL_IP_LINE=external-ip=your_ec2_ip

# 9. AI APIs
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
