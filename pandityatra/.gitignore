# ========================================
# PanditYatra - CLEAN .gitignore
# ========================================

# ===============================
# 1. ENVIRONMENT / SECRETS
# ===============================
.env
*.env
*.env.local
frontend/.env
frontend/*.env.*

# ===============================
# 2. BACKEND (DJANGO)
# ===============================
__pycache__/
*.pyc
*.pyo
*.pyd

venv/
env/
.venv/

db.sqlite3
db.sqlite3-journal

backend/staticfiles/
backend/media/
# Ignore backend apps (temporarily)


# If using logs
*.log

# ===============================
# 3. FRONTEND (React + Vite)
# ===============================
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Ignore the UI folder (your request)

# Package managers
pnpm-lock.yaml
npm-debug.log*
yarn-debug.log*

# ===============================
# 4. DOCKER
# ===============================
docker-volumes/
postgres_data/
docker-compose.override.yml

# ===============================
# 4.1 COTURN (runtime/secrets only)
# Keep coturn/turnserver.conf tracked (template/default config)
# ===============================
coturn/*.log
coturn/turnserver.local.conf
coturn/*.pem
coturn/*.crt
coturn/*.key
coturn/*.p12
coturn/*.pfx
coturn/db/

# ===============================
# 5. EDITORS
# ===============================
.vscode/
.idea/
*.swp
*.swo
*~

# ===============================
# 7. SCRATCH & TEST FILES
# ===============================
test_output*.txt
debug_*.py
*.log
scratch/
.gemini/
.antigravity/

test_*
debug_*
*.txt
*.out